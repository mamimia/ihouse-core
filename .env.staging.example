# iHouse Core — Staging Environment Variables
# Phase 237 — Staging Environment & Integration Tests
#
# Copy this file to .env.staging and fill in your local Supabase values.
# NEVER commit .env.staging to git.
#
# To spin up Supabase locally: https://supabase.com/docs/guides/cli/local-development
#   supabase start
#   supabase status   ← shows the values below

SUPABASE_URL=http://localhost:54321
SUPABASE_SERVICE_ROLE_KEY=<local-service-role-key-from-supabase-status>
SUPABASE_ANON_KEY=<local-anon-key-from-supabase-status>

# Must be at least 32 characters for HS256
IHOUSE_JWT_SECRET=staging-test-secret-replace-with-32-chars-min

IHOUSE_ENV=staging
PORT=8000

# Optional — needed only if testing LLM copilot endpoints
# OPENAI_API_KEY=sk-...
