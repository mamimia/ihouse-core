# iHouse Core — Environment Variables Example
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# Last updated: Phase 275 (2026-03-11)

# ─────────────────────────────────────────────
# Supabase (required)
# ─────────────────────────────────────────────
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ─────────────────────────────────────────────
# Authentication (required)
# ─────────────────────────────────────────────
# JWT secret — must be at least 32 characters
IHOUSE_JWT_SECRET=change-me-at-least-32-characters-long

# API key for service-to-service auth (internal)
IHOUSE_API_KEY=change-me-api-key

# Tenant ID
IHOUSE_TENANT_ID=your-tenant-id

# ─────────────────────────────────────────────
# Server (optional — defaults shown)
# ─────────────────────────────────────────────
PORT=8000
UVICORN_WORKERS=2

# ─────────────────────────────────────────────
# OTA Webhook Secrets (optional — disables HMAC if absent)
# ─────────────────────────────────────────────
IHOUSE_AIRBNB_WEBHOOK_SECRET=
IHOUSE_BOOKINGCOM_WEBHOOK_SECRET=
IHOUSE_STRIPE_WEBHOOK_SECRET=

# ─────────────────────────────────────────────
# Notification Channels (optional)
# ─────────────────────────────────────────────
IHOUSE_LINE_CHANNEL_TOKEN=
IHOUSE_TELEGRAM_BOT_TOKEN=
IHOUSE_WHATSAPP_TOKEN=
IHOUSE_SMS_TOKEN=
IHOUSE_EMAIL_TOKEN=

# ─────────────────────────────────────────────
# AI / LLM (optional — heuristic fallback if absent)
# ─────────────────────────────────────────────
OPENAI_API_KEY=

# ─────────────────────────────────────────────
# Scheduler (optional)
# ─────────────────────────────────────────────
IHOUSE_SCHEDULER_ENABLED=true
IHOUSE_SLA_SWEEP_INTERVAL=120
IHOUSE_DLQ_ALERT_INTERVAL=600

# ─────────────────────────────────────────────
# Environment flag
# ─────────────────────────────────────────────
# Options: development | staging | production
IHOUSE_ENV=development
