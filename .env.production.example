# iHouse Core — Production Environment Variables
# ================================================
# Copy this to .env on your production server. Fill ALL values.
# NEVER commit this file. NEVER use development defaults.
#
# Phase 278 — Production Environment Configuration (2026-03-11)
#
# SECURITY RULES:
#   1. IHOUSE_JWT_SECRET must be at least 64 characters (use: openssl rand -hex 32)
#   2. IHOUSE_API_KEY must be at least 32 characters (use: openssl rand -hex 16)
#   3. IHOUSE_DEV_MODE must be unset or "false" in production
#   4. IHOUSE_ENV must be "production"
#   5. Never share SUPABASE_SERVICE_ROLE_KEY — it bypasses all RLS policies

# ─────────────────────────────────────────────
# Supabase (REQUIRED — all 3)
# ─────────────────────────────────────────────
# From: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ─────────────────────────────────────────────
# Authentication (REQUIRED)
# ─────────────────────────────────────────────
# JWT secret — must match Supabase project JWT secret EXACTLY.
# Get from: Supabase Dashboard → Project Settings → API → JWT Settings
# Generate standalone: openssl rand -hex 32
IHOUSE_JWT_SECRET=<64-character-hex-string>

# Internal service-to-service API key (webhooks, inter-service)
# Generate: openssl rand -hex 16
IHOUSE_API_KEY=<32-character-hex-string>

# Tenant ID for this deployment instance
IHOUSE_TENANT_ID=<your-production-tenant-id>

# Dev mode MUST be false in production
IHOUSE_DEV_MODE=false

# ─────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────
PORT=8000
UVICORN_WORKERS=4

# ─────────────────────────────────────────────
# OTA Webhook Secrets (REQUIRED for each active OTA)
# ─────────────────────────────────────────────
# Airbnb — Webhook signing secret from Airbnb Partner Portal
IHOUSE_AIRBNB_WEBHOOK_SECRET=<airbnb-webhook-signing-secret>

# Booking.com — Webhook signing secret from Booking.com Connectivity Centre
IHOUSE_BOOKINGCOM_WEBHOOK_SECRET=<bookingdotcom-webhook-signing-secret>

# Stripe — Webhook signing secret from Stripe Dashboard → Developers → Webhooks
IHOUSE_STRIPE_WEBHOOK_SECRET=<stripe-webhook-signing-secret>

# ─────────────────────────────────────────────
# Notification Channels (set each active channel)
# ─────────────────────────────────────────────
# LINE Notify / LINE Messaging API — Channel Access Token
IHOUSE_LINE_CHANNEL_TOKEN=<line-channel-access-token>

# Telegram Bot — Bot API token from @BotFather
IHOUSE_TELEGRAM_BOT_TOKEN=<telegram-bot-token>

# WhatsApp Business — Permanent API token
IHOUSE_WHATSAPP_TOKEN=<whatsapp-business-token>

# SMS (Twilio or similar)
IHOUSE_SMS_TOKEN=<sms-provider-api-token>

# Transactional email (SendGrid, Mailgun etc.)
IHOUSE_EMAIL_TOKEN=<email-provider-api-token>

# ─────────────────────────────────────────────
# AI / LLM (optional — heuristic fallback if absent)
# ─────────────────────────────────────────────
OPENAI_API_KEY=<openai-api-key>

# ─────────────────────────────────────────────
# Scheduler
# ─────────────────────────────────────────────
IHOUSE_SCHEDULER_ENABLED=true
# SLA sweep interval in seconds (default 120 = 2 min)
IHOUSE_SLA_SWEEP_INTERVAL=120
# DLQ alert sweep interval in seconds (default 600 = 10 min)
IHOUSE_DLQ_ALERT_INTERVAL=600

# ─────────────────────────────────────────────
# Observability (optional)
# ─────────────────────────────────────────────
# Sentry DSN (error tracking)
SENTRY_DSN=

# ─────────────────────────────────────────────
# Environment flag (REQUIRED)
# ─────────────────────────────────────────────
IHOUSE_ENV=production
